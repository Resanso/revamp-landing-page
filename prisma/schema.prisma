// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Activity {
  id          String   @id @default(uuid())
  slug        String   @unique
  title       String
  date        DateTime
  category    String // "Event", "Information", "Articles"
  excerpt     String
  coverImage  String
  contentHtml String   @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ExecutiveMember {
  id        Int      @id @default(autoincrement())
  year      String // E.g., "2025"
  name      String
  nim       String
  prodi     String
  angkatan  String
  position  String
  linkedin  String?
  instagram String?
  image     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([nim, year])
}

model HallOfFame {
  id          Int      @id @default(autoincrement())
  year        String // E.g., "2024"
  title       String
  competition String
  image       String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model GalleryImage {
  id          Int      @id @default(autoincrement())
  year        String // E.g., "2025"
  fileName    String
  imageUrl    String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AdmissionResult {
  id        Int      @id @default(autoincrement())
  nim       String   @unique
  name      String
  position  String
  isPassed  Boolean  @map("lolos")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
